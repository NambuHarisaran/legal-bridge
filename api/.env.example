# ─── Legal Brdige — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# Get your key from: https://ai.google.dev/
GOOGLE_API_KEY=your-google-api-key-here

# Comma-separated model fallback order (first available model is used)
AI_MODEL_LIST=gemini-3-flash-preview,gemini-2.0-flash,gemini-2.0-flash-lite

# Frontend origin allowed by CORS (no trailing slash)
FRONTEND_ORIGIN=http://localhost:3000

# Firebase Admin credentials (choose one approach)

# 1) JSON string (recommended)
# Example: {"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_KEY=

# 2) Alternative JSON variable name (useful on some hosts)
FIREBASE_SERVICE_ACCOUNT_KEY_JSON=

# 3) Base64-encoded JSON string
FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=

# 4) Split service-account fields (common in Vercel UI)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Alternative to FIREBASE_SERVICE_ACCOUNT_KEY: absolute path to service account file
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

# Development only: when true, allows local requests if Firebase Admin is not configured.
# NEVER enable this in production.
DEV_AUTH_BYPASS=false
