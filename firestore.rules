rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validShortString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function validOptionalString(value, maxLen) {
      return !(value is string) || value.size() <= maxLen;
    }

    function validStringList(value, maxItems, maxItemLen) {
      return value is list && value.size() <= maxItems;
    }

    function validUserProfile() {
      return request.resource.data.keys().hasOnly([
        'name', 'email', 'phone', 'location', 'caseType', 'role', 'settings', 'createdAt', 'updatedAt'
      ]) &&
      validShortString(request.resource.data.name, 120) &&
      validOptionalString(request.resource.data.email, 160) &&
      validOptionalString(request.resource.data.phone, 30) &&
      validOptionalString(request.resource.data.location, 120) &&
      validOptionalString(request.resource.data.caseType, 120) &&
      validOptionalString(request.resource.data.role, 24) &&
      (request.resource.data.settings is map || !('settings' in request.resource.data));
    }

    function validUserProfileCreate() {
      return validUserProfile() &&
      (!('role' in request.resource.data) || request.resource.data.role == 'user');
    }

    function validUserProfileUpdate() {
      return validUserProfile() &&
      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
    }

    function validChatDoc() {
      return request.resource.data.keys().hasOnly(['role', 'text', 'timestamp']) &&
      request.resource.data.role in ['user', 'assistant'] &&
      validShortString(request.resource.data.text, 4000);
    }

    function validDocumentDoc() {
      return request.resource.data.keys().hasOnly(['filename', 'analysis', 'savedAt']) &&
      validShortString(request.resource.data.filename, 180) &&
      request.resource.data.analysis is map;
    }

    function validRiskDoc() {
      return request.resource.data.keys().hasOnly(['answers', 'result', 'risk_level', 'assessedAt']) &&
      request.resource.data.answers is map &&
      request.resource.data.result is map &&
      validOptionalString(request.resource.data.risk_level, 20);
    }

    function validComplaintDoc() {
      return request.resource.data.keys().hasOnly([
        'complaintType', 'subject', 'incident', 'parties', 'dates', 'location', 'evidence', 'requestedRelief', 'draftText', 'generatedAt'
      ]) &&
      validShortString(request.resource.data.complaintType, 40) &&
      validShortString(request.resource.data.subject, 180) &&
      validOptionalString(request.resource.data.incident, 6000) &&
      validStringList(request.resource.data.parties, 30, 180) &&
      validStringList(request.resource.data.dates, 30, 80) &&
      validStringList(request.resource.data.evidence, 50, 200) &&
      validOptionalString(request.resource.data.location, 240) &&
      validOptionalString(request.resource.data.requestedRelief, 3000) &&
      validOptionalString(request.resource.data.draftText, 10000);
    }

    function validSchemeActivityDoc() {
      return request.resource.data.keys().hasOnly([
        'schemeId', 'schemeName', 'action', 'state', 'portalUrl', 'createdAt'
      ]) &&
      validShortString(request.resource.data.schemeId, 220) &&
      validShortString(request.resource.data.schemeName, 220) &&
      request.resource.data.action in ['saved', 'applied'] &&
      validOptionalString(request.resource.data.state, 60) &&
      validOptionalString(request.resource.data.portalUrl, 300);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && validUserProfileCreate();
      allow update: if isOwner(uid) && validUserProfileUpdate();
      allow delete: if false;

      match /chats/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && validChatDoc();
        allow delete: if false;
      }

      match /documents/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && validDocumentDoc();
        allow delete: if false;
      }

      match /risk_assessments/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && validRiskDoc();
        allow delete: if false;
      }

      match /complaints/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && validComplaintDoc();
        allow delete: if false;
      }

      match /scheme_activity/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && validSchemeActivityDoc();
        allow delete: if false;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
