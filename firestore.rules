rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can read/write only their own root profile doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Each signed-in user can read/write only docs under their own subcollections.
      match /{subCollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
